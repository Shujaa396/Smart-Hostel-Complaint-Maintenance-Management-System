<%- include('../partials/header') %>
<div class="row gy-4">
  <div class="col-lg-3">
    <div class="card sidebar-card admin-sidebar border-0 shadow-sm">
      <div class="card-body">
        <h5 class="mb-3 fw-bold text-primary">Admin Menu</h5>
        <ul class="nav flex-column">
          <li class="nav-item"><a class="nav-link admin-menu-link" href="/admin/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link admin-menu-link" href="/admin/manage-complaints">Manage Complaints</a></li>
          <li class="nav-item"><a class="nav-link admin-menu-link active" href="/admin/manage-workers">Manage Workers</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="col-lg-9">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
          <div>
            <h3 class="mb-2">Add New Worker</h3>
            <p class="text-muted mb-0">Create a worker account and assign them to maintenance requests.</p>
          </div>
        </div>
        <form action="/admin/add-worker" method="POST" class="row g-3 mt-3">
          <div class="col-md-6">
            <label class="form-label">Name</label>
            <input type="text" name="name" class="form-control" placeholder="Worker name" required />
          </div>
          <div class="col-md-6">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" placeholder="worker@example.com" required />
          </div>
          <div class="col-md-6">
            <label class="form-label">Department</label>
            <select name="department" class="form-select" required>
              <option value="">Choose a department</option>
              <option value="Electrical">Electrical</option>
              <option value="Plumbing">Plumbing</option>
              <option value="Carpentry">Carpentry</option>
              <option value="Cleaning">Cleaning</option>
              <option value="HVAC">HVAC</option>
              <option value="Security">Security</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label">Phone</label>
            <input type="text" name="phone" class="form-control" placeholder="+1234567890" required />
          </div>
          <div class="col-12">
            <p class="text-muted">New workers are created with a default password of <strong>Worker@123</strong>. They can change it after first login.</p>
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-primary">Add Worker</button>
          </div>
        </form>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body table-responsive">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <div>
            <h3 class="mb-0">Worker List</h3>
            <p class="text-muted mb-0">Current staff members available for assignments.</p>
          </div>
        </div>
        <table class="table table-hover align-middle mb-0">
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Department</th>
              <th>Phone</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (workers.length) { %>
              <% workers.forEach((worker) => { %>
                <tr>
                  <td><%= worker.name %></td>
                  <td><%= worker.email %></td>
                  <td><%= worker.department %></td>
                  <td><%= worker.phone %></td>
                  <td class="text-end">
                    <a href="/admin/edit-worker/<%= worker.id %>" class="btn btn-sm btn-outline-primary shadow-sm rounded-pill px-3">
                      Edit
                    </a>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="4" class="text-muted">No workers have been added yet.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
