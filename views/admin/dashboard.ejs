<%- include('../partials/header') %>
<div class="row gy-4">
  <div class="col-lg-3">
    <div class="card sidebar-card admin-sidebar border-0 shadow-sm">
      <div class="card-body">
        <h5 class="mb-3">Admin Menu</h5>
        <ul class="nav flex-column">
          <li class="nav-item"><a class="nav-link" href="/admin/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/manage-complaints">Manage Complaints</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/manage-workers">Manage Workers</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="col-lg-9">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2>Admin Dashboard</h2>
        <p class="text-muted">Use admin controls to review complaints, track issues, and manage workers.</p>
      </div>
      <a class="btn btn-outline-primary" href="/admin/manage-workers">Manage Workers</a>
    </div>

    <div class="row g-4 mb-4">
      <div class="col-md-4">
        <div class="card stat-card bg-info text-dark shadow-sm border-0">
          <div class="card-body">
            <span class="text-uppercase small">Total Complaints</span>
            <h3 class="mt-3"><%= stats.total || 0 %></h3>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card stat-card bg-warning text-dark shadow-sm border-0">
          <div class="card-body">
            <span class="text-uppercase small">Pending</span>
            <h3 class="mt-3"><%= stats.pending || 0 %></h3>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card stat-card bg-success text-white shadow-sm border-0">
          <div class="card-body">
            <span class="text-uppercase small">Completed</span>
            <h3 class="mt-3"><%= stats.completed || 0 %></h3>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-md-6">
        <div class="card page-card border-0 shadow-sm">
          <div class="card-body">
            <h5 class="card-title">Total Workers</h5>
            <p class="display-6 mb-0"><%= workerCount || 0 %></p>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card page-card border-0 shadow-sm">
          <div class="card-body">
            <h5 class="card-title">Quick Actions</h5>
            <a class="btn btn-primary me-2" href="/admin/manage-workers">Add Worker</a>
            <a class="btn btn-secondary" href="/admin/manage-complaints">Review Complaints</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>

