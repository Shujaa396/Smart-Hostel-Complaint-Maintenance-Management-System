<%- include('../partials/header') %>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/admin/manage-workers" class="text-decoration-none">Manage Workers</a></li>
          <li class="breadcrumb-item active" aria-current="page">Edit Worker</li>
        </ol>
      </nav>

      <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header bg-primary text-white p-4">
          <h3 class="mb-0 fw-bold">Update Worker Details</h3>
          <p class="text-white-50 mb-0 small">Modify profile and account information for <%= worker.name %></p>
        </div>
        <div class="card-body p-4 p-md-5 bg-white">
          <% if (error_msg) { %>
            <div class="alert alert-danger rounded-3 border-0 shadow-sm"><%= error_msg %></div>
          <% } %>
          <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger rounded-3 border-0 shadow-sm">
              <ul class="mb-0">
                <% errors.forEach(err => { %>
                  <li><%= err %></li>
                <% }) %>
              </ul>
            </div>
          <% } %>
          
          <form action="/admin/edit-worker/<%= worker.id %>" method="POST">
            <div class="row g-4">
              <div class="col-md-6">
                <label class="form-label fw-semibold small text-muted text-uppercase">Full Name</label>
                <input type="text" name="name" class="form-control form-control-lg bg-light border-0" value="<%= worker.name %>" required />
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold small text-muted text-uppercase">Email Address</label>
                <input type="email" name="email" class="form-control form-control-lg bg-light border-0" value="<%= worker.email %>" required />
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold small text-muted text-uppercase">Department</label>
                <select name="department" class="form-select form-select-lg bg-light border-0" required>
                  <% ['Electrical', 'Plumbing', 'Carpentry', 'Cleaning', 'HVAC', 'Security'].forEach(dept => { %>
                    <option value="<%= dept %>" <%= worker.department === dept ? 'selected' : '' %>><%= dept %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold small text-muted text-uppercase">Phone Number</label>
                <input type="text" name="phone" class="form-control form-control-lg bg-light border-0" value="<%= worker.phone %>" required />
              </div>
              <div class="col-12 mt-5">
                <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm">Save Changes</button>
                <a href="/admin/manage-workers" class="btn btn-link w-100 mt-2 text-decoration-none text-muted">Discard Changes</a>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>