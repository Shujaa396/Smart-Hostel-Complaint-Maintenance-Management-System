<%- include('../partials/header') %>
<div class="row gy-4">
  <div class="col-lg-3">
    <div class="card sidebar-card admin-sidebar border-0 shadow-sm">
      <div class="card-body">
        <h5 class="mb-3">Worker Menu</h5>
        <ul class="nav flex-column">
          <li class="nav-item"><a class="nav-link" href="/worker/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/worker/assigned-complaints">Assigned Complaints</a></li>
        </ul>
      </div>
    </div>
  </div>
  <div class="col-lg-9">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2>Worker Dashboard</h2>
        <p class="text-muted">Track assigned requests and update progress here.</p>
      </div>
      <a class="btn btn-outline-primary" href="/worker/assigned-complaints">View Assigned</a>
    </div>

    <div class="row g-4 mb-4">
      <div class="col-md-4">
        <div class="card stat-card bg-info text-dark shadow-sm border-0">
          <div class="card-body">
            <span class="text-uppercase small">Assigned</span>
            <h3 class="mt-3"><%= assigned %></h3>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card stat-card bg-warning text-dark shadow-sm border-0">
          <div class="card-body">
            <span class="text-uppercase small">In Progress</span>
            <h3 class="mt-3"><%= inProgress %></h3>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card stat-card bg-success text-white shadow-sm border-0">
          <div class="card-body">
            <span class="text-uppercase small">Completed</span>
            <h3 class="mt-3"><%= completed %></h3>
          </div>
        </div>
      </div>
    </div>

    <div class="card page-card border-0 shadow-sm">
      <div class="card-body">
        <h5 class="card-title mb-3">Recent Tasks</h5>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead>
              <tr>
                <th>Complaint</th>
                <th>Student</th>
                <th>Status</th>
                <th>Since</th>
              </tr>
            </thead>
            <tbody>
              <% if (assignments.length) { %>
                <% assignments.slice(0, 6).forEach((item) => { %>
                  <tr>
                    <td><%= item.title %></td>
                    <td><%= item.student_name %></td>
                    <td><span class="badge <%= item.status === 'Completed' ? 'bg-success' : item.status === 'In Progress' ? 'bg-warning text-dark' : item.status === 'Assigned' ? 'bg-info text-dark' : 'bg-secondary' %>"><%= item.status %></span></td>
                    <td><%= new Date(item.assigned_at).toLocaleDateString() %></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="4" class="text-muted">No assigned complaints available.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>

