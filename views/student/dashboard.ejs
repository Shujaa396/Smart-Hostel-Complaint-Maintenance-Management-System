<%- include('../partials/header') %>
<div class="row gy-4">
  <div class="col-lg-3">
    <div class="card sidebar-card student-sidebar border-0 shadow-sm">
      <div class="card-body">
        <h5 class="mb-3">Student Menu</h5>
        <ul class="nav flex-column">
          <li class="nav-item"><a class="nav-link student-menu-link active" href="/student/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link student-menu-link" href="/student/create-complaint">Create Complaint</a></li>
          <li class="nav-item"><a class="nav-link student-menu-link" href="/student/my-complaints">My Complaints</a></li>
        </ul>
      </div>
    </div>
  </div>
  <div class="col-lg-9">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="mb-1">Student Dashboard</h2>
        <p class="text-muted">Welcome back, <%= user.name %>. Track your hostel complaints and statuses.</p>
      </div>
      <a class="btn btn-outline-primary" href="/student/create-complaint"><i class="fa fa-plus-circle me-2"></i>New Complaint</a>
    </div>

    <div class="row g-4 mb-4">
      <div class="col-md-4">
        <div class="card stat-card student-stat-card student-stat-pending shadow-sm border-0">
          <div class="card-body">
            <span class="text-uppercase small text-muted">Pending</span>
            <h3 class="mt-3"><%= pending %></h3>
            <p class="mb-0 text-secondary">Issues waiting for review.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card stat-card student-stat-card student-stat-progress shadow-sm border-0">
          <div class="card-body">
            <span class="text-uppercase small text-muted">In Progress</span>
            <h3 class="mt-3"><%= inProgress %></h3>
            <p class="mb-0 text-secondary">Work currently being addressed.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card stat-card student-stat-card student-stat-completed shadow-sm border-0">
          <div class="card-body">
            <span class="text-uppercase small text-muted">Completed</span>
            <h3 class="mt-3"><%= completed %></h3>
            <p class="mb-0 text-secondary">Resolved and closed requests.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm student-complaint-card">
      <div class="card-body">
        <h5 class="card-title mb-3">Recent Complaints</h5>
        <div class="table-responsive">
          <table class="table align-middle mb-0 student-complaint-table">
            <thead>
              <tr>
                <th>Title</th>
                <th>Category</th>
                <th>Status</th>
                <th>Priority</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% if (complaints.length) { %>
                <% complaints.slice(0, 6).forEach((complaint) => { %>
                  <tr>
                    <td><%= complaint.title %></td>
                    <td><%= complaint.category %></td>
                    <td><span class="badge <%= complaint.status === 'Completed' ? 'bg-success' : complaint.status === 'In Progress' ? 'bg-warning text-dark' : complaint.status === 'Assigned' ? 'bg-info text-dark' : 'bg-secondary' %>"><%= complaint.status %></span></td>
                    <td><span class="badge bg-dark"><%= complaint.priority %></span></td>
                    <td><%= new Date(complaint.created_at).toLocaleDateString() %></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="5" class="text-muted">No complaints yet. Submit one now.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>

