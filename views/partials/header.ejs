<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Smart Hostel</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold text-dark" href="/">Smart Hostel</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto align-items-center">
          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>
          <% if (!user) { %>
            <li class="nav-item">
              <a class="nav-link" href="/login">Login</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/register">Register</a>
            </li>
          <% } else { %>
            <% if (user.role === 'student') { %>
              <li class="nav-item"><a class="nav-link" href="/student/dashboard">Dashboard</a></li>
            <% } %>
            <% if (user.role === 'admin') { %>
              <li class="nav-item"><a class="nav-link" href="/admin/dashboard">Dashboard</a></li>
            <% } %>
            <% if (user.role === 'worker') { %>
              <li class="nav-item"><a class="nav-link" href="/worker/dashboard">Dashboard</a></li>
            <% } %>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"><i class="fa fa-user"></i> <%= user.name %></a>
              <ul class="dropdown-menu dropdown-menu-end bg-white">
                <li><a class="dropdown-item text-dark" href="/logout">Logout</a></li>
              </ul>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>
  <main class="main-content">
    <div class="container py-5">
      <%- include('./alerts') %>
