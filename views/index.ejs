<%- include('partials/header') %>

<style>
  .hero-container {
    min-height: 80vh;
    display: flex;
    align-items: center;
  }
  .text-navy { color: #1e293b; }
  .bg-navy { background-color: #1e293b; }
  .ls-wide { letter-spacing: 0.05em; }
  .hover-lift { transition: all 0.3s ease; }
  .hover-lift:hover { transform: translateY(-5px); }
</style>

<div class="container hero-container">
  <div class="row align-items-center py-5">
    <div class="col-lg-6 text-center text-lg-start">
      <div class="hero-content pe-lg-5">
        <span class="badge bg-primary px-3 py-2 rounded-pill mb-4 shadow-sm ls-wide text-uppercase">Smart Maintenance Portal</span>
        <h1 class="display-4 fw-bold text-navy mb-4">Hostel living, simplified with smart reporting.</h1>
        <p class="lead text-muted mb-5">Our unified system connects students, administrators, and maintenance staff to ensure every hostel issue is resolved swiftly and transparently.</p>
        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-lg-start">
          <a class="btn btn-primary btn-lg px-5 py-3 rounded-pill shadow-sm fw-bold" href="/register">Join the Portal</a>
          <a class="btn btn-outline-primary btn-lg px-5 py-3 rounded-pill fw-bold" href="/login">Portal Login</a>
        </div>
      </div>
    </div>
    <div class="col-lg-6 d-none d-lg-block">
      <div class="card border-0 shadow-lg rounded-5 bg-white p-2">
        <div class="card-body p-4 p-xl-5">
          <h5 class="fw-bold text-primary mb-2 ls-wide small">GET STARTED</h5>
          <h2 class="fw-bold text-navy mb-4">Access your workspace</h2>
          <div class="d-grid gap-3">
            <a href="/student/dashboard" class="btn btn-light py-4 px-4 rounded-4 text-start border-0 shadow-sm hover-lift bg-opacity-10">
              <div class="text-navy fw-bold mb-1">Student Hub</div>
              <div class="text-muted small">Lodge a new complaint and track status.</div>
            </a>
            <a href="/admin/dashboard" class="btn btn-light py-4 px-4 rounded-4 text-start border-0 shadow-sm hover-lift bg-opacity-10">
              <div class="text-navy fw-bold mb-1">Administrator Suite</div>
              <div class="text-muted small">Manage staff and maintenance workflows.</div>
            </a>
            <a href="/login" class="btn btn-light py-4 px-4 rounded-4 text-start border-0 shadow-sm hover-lift bg-opacity-10">
              <div class="text-navy fw-bold mb-1">Maintenance Team</div>
              <div class="text-muted small">View and update your assigned tasks.</div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
